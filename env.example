# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/reviewflow"

# Auth (required) — use a long random string in production
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional: superuser login — same as normal sign-in at /auth
# Email must match ADMIN_USERNAME; password must match ADMIN_PASSWORD.
# Registers using this email are blocked. User is upserted to PRO with alerts on.
ADMIN_USERNAME="admin@yourdomain.com"
ADMIN_PASSWORD="change-me-to-a-strong-secret"

# Email (Resend) — required for PRO private-feedback notifications to the owner’s inbox
# Get an API key at https://resend.com — use a verified domain in production for `from`.
RESEND_API_KEY="re_xxxxxxxx"
# Optional. Default: ReviewFlow <onboarding@resend.dev> (testing only; limited recipients).
EMAIL_FROM="ReviewFlow <notifications@yourdomain.com>"

# Stripe / PayPal / GA — add as needed for your deployment
